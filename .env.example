# Production admin API (same domain as user app)
# Production admin API (VPS nginx: /api/admin/ → port 8082). Either domain works.
EXPO_PUBLIC_ADMIN_API_BASE_URL=https://flintnthread.in
# EXPO_PUBLIC_ADMIN_API_BASE_URL=https://flintnthread.in

# Media CDN (matches admin-backend app.media.public-base-url)
EXPO_PUBLIC_MEDIA_BASE_URL=https://flintnthread.in

# Login: admin user from your database
# Or bootstrap: admin@flintnthread.in / Admin@12345

# --- Local dev only ---
# EXPO_PUBLIC_ADMIN_API_USE_LOCAL=true
# EXPO_PUBLIC_ADMIN_API_WEB_BASE_URL=http://localhost:8082
