# Admin API (admin-backend runs on port 8082)
EXPO_PUBLIC_ADMIN_API_BASE_URL=http://localhost:8082

# Login: use existing DB admin (e.g. admin@gmail.com / 12345)
# Or bootstrap user from application.properties: admin@flintnthread.in / Admin@12345

# Web override (optional)
# EXPO_PUBLIC_ADMIN_API_WEB_BASE_URL=http://localhost:8082

# Physical device: use your PC LAN IP, e.g. http://192.168.1.5:8082
