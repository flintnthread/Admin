# Admin API (port 8082) — no LAN IP needed; Expo auto-detects your PC on phone/tablet.

# Web browser on this PC — open http://localhost:8081/login
EXPO_PUBLIC_ADMIN_API_WEB_BASE_URL=http://localhost:8082


# Physical phone / tablet (Expo Go). Replace with your PC IPv4 from ipconfig:
 EXPO_PUBLIC_ADMIN_API_BASE_URL=http://192.168.1.39:8082    

# Media CDN (matches admin-backend app.media.public-base-url)
EXPO_PUBLIC_MEDIA_BASE_URL=https://flintnthread.in


# Android emulator only (optional — 10.0.2.2 is tried automatically):
# EXPO_PUBLIC_ANDROID_EMULATOR_API=true

# Optional manual override (normally leave unset):
# EXPO_PUBLIC_ADMIN_API_BASE_URL=http://localhost:8082
