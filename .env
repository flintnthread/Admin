# Production admin API (VPS nginx: /api/admin/ → port 8082)
EXPO_PUBLIC_ADMIN_API_BASE_URL=https://flintnthread.in

# Media CDN (product/seller images)
EXPO_PUBLIC_MEDIA_BASE_URL=https://flintnthread.com

# --- Local dev only (uncomment to use PC backend instead of VPS) ---
# EXPO_PUBLIC_ADMIN_API_USE_LOCAL=true
# EXPO_PUBLIC_ADMIN_API_WEB_BASE_URL=http://localhost:8082
# EXPO_PUBLIC_ADMIN_API_BASE_URL=http://192.168.1.39:8082
