# Admin API (admin-backend on port 8082)

# Web browser on this PC
EXPO_PUBLIC_ADMIN_API_WEB_BASE_URL=http://localhost:8082

# Native mobile: leave unset to auto-detect PC IP via Expo Go (recommended).
# Only set if auto-detect fails on a physical device:
# EXPO_PUBLIC_ADMIN_API_BASE_URL=http://YOUR_PC_LAN_IP:8082
