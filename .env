# Admin API (admin-backend on port 8082)

# Web browser on this PC — API stays on 8082, open app at http://localhost:8081/login
EXPO_PUBLIC_ADMIN_API_WEB_BASE_URL=http://localhost:8082

# Physical phone / tablet (Expo Go). Replace with your PC IPv4 from ipconfig:
 EXPO_PUBLIC_ADMIN_API_BASE_URL=http://192.168.1.35:8082    

# Android emulator only (optional — 10.0.2.2 is tried automatically):
# EXPO_PUBLIC_ANDROID_EMULATOR_API=true
